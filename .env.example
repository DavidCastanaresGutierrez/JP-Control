# Postgres connection string. Neon normally creates this in Vercel.
DATABASE_URL=
POSTGRES_URL=

# Legacy shared app token. Leave empty when SSO is enabled.
APP_TOKEN=

# TYPSA SSO frontend authorize URL.
VITE_TYPSA_SSO_URL=

# App JWT secret for SSO sessions. Use a long random value in Vercel.
JWT_SECRET=
JWT_TOKEN_EXPIRY=24h

# TYPSA SSO refresh endpoint (Lambda): {ssoUrl}/refresh-token.
# Enables silent session renewal when the app JWT expires.
SSO_AWS_LAMBDA_URL=

# Optional hardening. Fill COGNITO_ISSUER with the issuer from the SSO id_token.
COGNITO_ISSUER=
SSO_COOKIE_DOMAIN=
