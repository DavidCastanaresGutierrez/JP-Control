{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/((?!api/|assets/).*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
